# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://kickwise.app

# Football-Data.org — free key from https://www.football-data.org/client/register
# Without this set, the app falls back to bundled demo fixtures.
FOOTBALL_DATA_TOKEN=

# The-Odds-API — free 500 req/month from https://the-odds-api.com
# Without this, value-bet flags will be suppressed but predictions still display.
ODDS_API_KEY=

# Affiliate IDs — fill these in after signing up to each programme.
# These are read on the client (NEXT_PUBLIC_) so they ship to the browser,
# which is fine — affiliate IDs are not secret.
NEXT_PUBLIC_AFF_SPORTYBET=
NEXT_PUBLIC_AFF_BETKING=
NEXT_PUBLIC_AFF_1XBET=
NEXT_PUBLIC_AFF_BETWINNER=
NEXT_PUBLIC_AFF_MSPORT=
