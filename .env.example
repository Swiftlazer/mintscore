# Primary provider — sign up at https://betloy.com
# Free tier: 10 conversions/month (caching stretches this significantly)
BETLOY_API_KEY=

# Fallback 1 — sign up at https://betpaddi.com/developers
# Pricing not public; request access after signup
BETPADDI_API_KEY=

# Fallback 2 — request key from https://convertbetcodes.com
CONVERTBETCODES_API_KEY=

# Country code for ConvertBetCodes (ng = Nigeria, ke = Kenya, gh = Ghana, etc.)
# Defaults to 'ng' if unset
BCC_COUNTRY=ng

PORT=3000
